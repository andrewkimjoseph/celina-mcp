{
  "name": "@andrewkimjoseph/celo-mcp",
  "version": "0.1.0",
  "description": "MCP server for Celo — balances, transfers, swaps, and chain reads for LLM agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "celo-mcp": "./bin/cli.js"
  },
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "celo",
    "blockchain",
    "web3",
    "ai",
    "agent"
  ],
  "author": "Andrew Kim Joseph",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "viem": "^2.39.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
